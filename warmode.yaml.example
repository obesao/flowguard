# warmode.yaml — config do "botão de emergência" (Modo Guerra).
#
# Copie este arquivo pra warmode.yaml (fica fora do git, .gitignore já cobre) e
# preencha host/usuário/senha/comandos reais. warmode.yaml tem senha em texto
# puro — mesma proteção que /root/ai/.env: permissão de arquivo (chmod 600,
# root-only), não é exposto por HTTP em lugar nenhum, nunca vai pro git.
#
# device_type usa os drivers do Netmiko (https://github.com/ktbyers/netmiko) —
# os mais relevantes aqui: huawei_vrpv8 (NE8000 de verdade — modelo de config
# candidata com "commit", ver nota abaixo) e a10 (A10 Thunder/ACOS).
#
# ATENÇÃO — achado real (2026-07-02): "huawei_vrp" (sem "v8") NÃO funciona
# pra aplicar config (send_config_set) num NE8000 de carrier real. Esse
# equipamento usa o modelo de configuração candidata (prompt some com "~"/"*"
# quando há mudança não commitada) — ao sair do modo de configuração, o VRP
# pergunta interativamente "Uncommitted configurations found, commit them
# before exiting? [Y/N/C]", e o driver "huawei_vrp" não sabe responder isso,
# travando até estourar o timeout ("Pattern not detected: '>' in output").
# "huawei_vrpv8" já sabe fazer o commit sozinho antes de sair. Comandos de
# LEITURA (display ...) funcionam com qualquer um dos dois — só send_config_set
# (aplicar mudança de verdade) precisa do driver certo.
# `enable_mode: true` faz o Netmiko chamar `enable` com enable_secret antes dos
# comandos, se o equipamento precisar (normalmente não precisa em VRP/ACOS).
#
# Comandos rodam em sequência dentro de UM equipamento, mas todos os
# equipamentos rodam em PARALELO entre si (pra não perder tempo num cenário de
# ataque acontecendo agora).
#
# revert_commands (opcional): rodados pelo botão "Sair do Modo Guerra" — o
# inverso dos "commands" (ex.: se "commands" faz "undo rule 5"/"rule 5 permit
# ...", "revert_commands" desfaz isso de volta pro estado original). Mesmo
# formato/regras de "commands" (system-view como primeiro item entra em modo
# de configuração automaticamente). Equipamento sem revert_commands configurado
# simplesmente não roda nada no "Sair do Modo Guerra" (erro tratado, não trava
# os outros equipamentos).

devices:
  - name: "NE8000BGP"
    host: 10.77.10.1
    port: 22
    device_type: huawei_vrpv8
    username: admin
    password: "TROQUE_AQUI"
    enable_mode: false
    commands: []   # ex.: ["system-view", "..."]
    revert_commands: []   # ex.: ["system-view", "..."] pra desfazer o acima

  - name: "A10 Thunder"
    host: 0.0.0.0
    port: 22
    device_type: a10
    username: admin
    password: "TROQUE_AQUI"
    enable_mode: false
    commands: []   # a definir
    revert_commands: []   # a definir
